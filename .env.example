# ───────────────────────────────────────────────────────────────────────────────
# 🔐 NEXTAUTH — Authentication
# ───────────────────────────────────────────────────────────────────────────────
# URL التطبيق (غيّره عند الانتقال للـ production)
NEXTAUTH_URL=http://localhost:3000

# سرّي للتشفير — ولّده بـ: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_key_here_change_in_production

# ───────────────────────────────────────────────────────────────────────────────
# 💳 MYFATOORAH — Payment Gateway (Mada, STC Pay, Apple Pay, BNPL)
# ───────────────────────────────────────────────────────────────────────────────
# احصل عليها من: https://www.myfatoorah.com/developer
# استخدام Sandbox للتطوير:
# https://myfatoorah-api-test.azurewebsites.net
# استخدام Production للإطلاق:
# https://api.myfatoorah.com

PAYMENT_MODE=production
MYFATOORAH_API_URL=https://api-sa.myfatoorah.com
MYFATOORAH_API_KEY=SK_SAU_R9xULR1GuerJUt5NNc8Ka18gF6vOEmu2ldALYqmIjCzRWfX6nFg65K6Fe0HSR55M
MYFATOORAH_WEBHOOK_SECRET=WUeARgSh/zQeAhiEDaX3EdL+odklLDT4nFGlLRuawzv7jbJwdfzXpBu8/qVD7QE2ArCUnxoxhzFrN1JZbACJcg==

# ───────────────────────────────────────────────────────────────────────────────
# ☁️ CLOUDFLARE — DNS + Custom Domains + SSL
# ───────────────────────────────────────────────────────────────────────────────
# احصل عليها من: https://dash.cloudflare.com/profile/api-tokens
# تحتاج: Zone ID + API Token مع صلاحيات:
# - Zone:DNS:Edit
# - Zone:Custom Hostname:Edit

CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# ───────────────────────────────────────────────────────────────────────────────
# 📧 EMAIL CONFIGURATION — Transactional Emails
# ───────────────────────────────────────────────────────────────────────────────
# خيار 1: Resend (موصى به)
# احصل عليها من: https://resend.com/api-keys

RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# خيار 2: Custom SMTP (اختياري)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_password

# ───────────────────────────────────────────────────────────────────────────────
# 📊 UPSTASH REDIS — Cache + Rate Limiting
# ───────────────────────────────────────────────────────────────────────────────
# احصل عليها من: https://console.upstash.com/redis
# أنشئ Database جديد واختر HTTP API

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ───────────────────────────────────────────────────────────────────────────────
# 🌐 APP CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# URL التطبيق الكامل (بدون trailing slash)
# غيّره عند الانتقال للـ production

APP_URL=http://localhost:3000

# اسم المنصة (يظهر في الـ UI والإيميلات)
APP_NAME=SaaS Core

# Domain المستخدم للـ subdomains (لـ Multi-tenancy)
# في التطوير: localhost:3000
# في production: platform.sa مثلاً
PLATFORM_DOMAIN=localhost:3000

# بيئة التشغيل (development | production)
NODE_ENV=development

# ───────────────────────────────────────────────────────────────────────────────
# 🎨 THEME CONFIGURATION (اختياري)
# ───────────────────────────────────────────────────────────────────────────────
# الألوان الأساسية (يمكن تعديلها من الـ Dashboard لاحقاً)

PRIMARY_COLOR=#6c63ff
SECONDARY_COLOR=#00d4aa

# ───────────────────────────────────────────────────────────────────────────────
# 🔔 NOTIFICATIONS (اختياري)
# ───────────────────────────────────────────────────────────────────────────────
# Knock — Notification Hub (اختياري — للمرحلة المتقدمة)
# https://www.knock.app/

KNOCK_API_KEY=your_knock_api_key_here
KNOCH_WORKFLOW_ID=your_workflow_id_here

# ───────────────────────────────────────────────────────────────────────────────
# 🤖 AI INTEGRATION (اختياري — للمرحلة المتقدمة)
# ───────────────────────────────────────────────────────────────────────────────
# Vercel AI SDK — لوكلاء AI
# https://sdk.vercel.ai/docs

OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Anthropic/Qwen AI — للتسويق بالذكاء الاصطناعي
# احصل على التوكن من: https://coding-intl.dashscope.aliyuncs.com
ANTHROPIC_AUTH_TOKEN=sk-sp-your-token-here
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.5-plus

# AI Settings
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_TIMEOUT=30000

# Msaed.ai — للوكلاء العرب (اختياري)
MSAED_API_KEY=your_msaed_api_key_here

# ───────────────────────────────────────────────────────────────────────────────
# 📈 ANALYTICS (اختياري)
# ───────────────────────────────────────────────────────────────────────────────
# Vercel Analytics — مدمج تلقائياً مع Vercel hosting
# https://vercel.com/analytics

NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id_here

# Sentry — Error Tracking (اختياري)
# https://sentry.io/
SENTRY_DSN=https://your_sentry_key_here

# ───────────────────────────────────────────────────────────────────────────────
# 🚀 DEPLOYMENT (اختياري — للـ Self-hosting)
# ───────────────────────────────────────────────────────────────────────────────
# Coolify — بديل Vercel للـ self-hosting
# https://coolify.io/

COOLIFY_API_URL=https://your-coolify-instance.com
COOLIFY_API_KEY=your_coolify_api_key_here

# ───────────────────────────────────────────────────────────────────────────────
# 🧪 FEATURE FLAGS (اختياري — للمرحلة المتقدمة)
# ───────────────────────────────────────────────────────────────────────────────
# تفعيل/تعطيل ميزات معينة

ENABLE_ECOMMERCE_MODULE=true
ENABLE_PAGE_BUILDER_MODULE=false
ENABLE_ACCOUNTING_MODULE=false
ENABLE_HRMS_MODULE=false
ENABLE_CRM_MODULE=false
ENABLE_AI_AGENT_MODULE=false

# ───────────────────────────────────────────────────────────────────────────────
# ⚙️ ADVANCED CONFIGURATION (اختياري)
# ───────────────────────────────────────────────────────────────────────────────
# Rate Limiting — عدد الطلبات المسموحة في الدقيقة
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Session — مدة الجلسة (بالأيام)
SESSION_MAX_AGE_DAYS=30

# Trial — مدة التجربة المجانية (بالأيام)
TRIAL_PERIOD_DAYS=14

# Cron Jobs Secret - للحماية
CRON_SECRET=your_cron_secret_here_generate_random_string

# ───────────────────────────────────────────────────────────────────────────────
# 📝 ملاحظات مهمة
# ───────────────────────────────────────────────────────────────────────────────
#
# 1. ⚠️  لا تشارك ملف .env.local أبداً — أضفه إلى .gitignore
#
# 2. 🔐  في production، استخدم قيم قوية لـ NEXTAUTH_SECRET
#      ولّده بـ: openssl rand -base64 32
#
# 3. 🌍  غيّر NEXTAUTH_URL و APP_URL إلى domain الفعلي عند الإطلاق
#
# 4. 💳  استخدم Sandbox MyFatoorah للتطوير فقط:
#      https://myfatoorah-api-test.azurewebsites.net
#
# 5. ☁️  لـ Custom Domains، تحتاج Cloudflare Enterprise أو:
#      - SSL for SaaS add-on
#      - أو استخدم Caddy Server مع Let's Encrypt كبديل مجاني
#
# 6. 📧  في Resend، يجب التحقق من domain قبل الإرسال
#
# ═══════════════════════════════════════════════════════════════════════════════
