    "supabase:gen:types": "supabase gen types typescript --project-id your-project-id > src/lib/supabase/types.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepare": "husky install"
